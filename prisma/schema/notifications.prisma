model Notification {
    id      String     @id @default(uuid())
    message String
    type    IdeaStatus
    status  IdeaStatus
    userId  String
    user    User       @relation(fields: [userId], references: [id])

    postId String?
    post   Idea?   @relation(fields: [postId], references: [id])

    isRead    Boolean  @default(false)
    createdAt DateTime @default(now())
}
